@page "/products/{Id:guid}"
@attribute [Authorize(Policy = AuthPolicies.ProductsRead)]
@inject ProductsApiClient ProductsApiClient
@inject ISnackbar Snackbar

<PageTitle>Product Detail</PageTitle>

@if (_isLoading)
{
    <MudStack AlignItems="AlignItems.Center" Class="pa-8">
        <MudProgressCircular Indeterminate="true" />
    </MudStack>
}
else if (_product is null)
{
    <MudAlert Severity="Severity.Warning">Product not found.</MudAlert>
}
else
{
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h4">@_product.Code</MudText>
                <MudText Typo="Typo.body2">@_product.Sku</MudText>
            </MudStack>

            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           Href="products">
                    Back
                </MudButton>

                <AuthorizeView Policy="@AuthPolicies.ProductsWrite">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Edit"
                               Href="@($"/products/{Id}/edit")">
                        Edit
                    </MudButton>
                </AuthorizeView>
            </MudStack>
        </MudStack>

        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Spacing="3">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudChip T="string" Color="@(_product.IsActive ? Color.Success : Color.Default)">
                        @(_product.IsActive ? "Active" : "Inactive")
                    </MudChip>
                    <MudText Typo="Typo.body2">
                        Created @FormatDate(_product.CreatedAtUtc)
                    </MudText>
                    @if (_product.UpdatedAtUtc is not null)
                    {
                        <MudText Typo="Typo.body2">
                            Updated @FormatDate(_product.UpdatedAtUtc.Value)
                        </MudText>
                    }
                </MudStack>

                <MudSimpleTable Dense="true" Hover="true">
                    <tbody>
                        <tr>
                            <td>Code</td>
                            <td>@_product.Code</td>
                        </tr>
                        <tr>
                            <td>SKU</td>
                            <td>@_product.Sku</td>
                        </tr>
                        <tr>
                            <td>Category</td>
                            <td>@DisplayCategory(_product)</td>
                        </tr>
                        <tr>
                            <td>Description</td>
                            <td>@DisplayDescription(_product)</td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudStack>
        </MudPaper>
    </MudStack>
}

@code {
    private ProductResponse? _product;
    private bool _isLoading = true;

    [Parameter]
    public Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _product = await ProductsApiClient.GetByIdAsync(Id);
        }
        catch (ApiException exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string DisplayCategory(ProductResponse product)
    {
        return string.IsNullOrWhiteSpace(product.CategoryName)
            ? "-"
            : product.CategoryName;
    }

    private static string DisplayDescription(ProductResponse product)
    {
        return string.IsNullOrWhiteSpace(product.Description)
            ? "-"
            : product.Description;
    }

    private static string FormatDate(DateTimeOffset value)
    {
        return value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }
}
