@page "/categories/{Id:guid}"
@attribute [Authorize(Policy = AuthPolicies.CategoriesRead)]
@inject CategoriesApiClient CategoriesApiClient
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Category Detail</PageTitle>

@if (_isLoading)
{
    <MudStack AlignItems="AlignItems.Center" Class="pa-8">
        <MudProgressCircular Indeterminate="true" />
    </MudStack>
}
else if (_category is null)
{
    <MudAlert Severity="Severity.Warning">Category not found.</MudAlert>
}
else
{
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h4">@_category.Name</MudText>
                <MudText Typo="Typo.body2">Product classification category</MudText>
            </MudStack>

            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           Href="categories">
                    Back
                </MudButton>

                <AuthorizeView Policy="@AuthPolicies.CategoriesWrite">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Edit"
                               Href="@($"/categories/{Id}/edit")">
                        Edit
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               Disabled="_isDeleting"
                               StartIcon="@Icons.Material.Filled.Delete"
                               OnClick="ConfirmDeleteAsync">
                        Delete
                    </MudButton>
                </AuthorizeView>
            </MudStack>
        </MudStack>

        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Spacing="3">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudChip T="string" Color="@(_category.IsActive ? Color.Success : Color.Default)">
                        @(_category.IsActive ? "Active" : "Inactive")
                    </MudChip>
                    <MudText Typo="Typo.body2">
                        Created @FormatDate(_category.CreatedAtUtc)
                    </MudText>
                    @if (_category.UpdatedAtUtc is not null)
                    {
                        <MudText Typo="Typo.body2">
                            Updated @FormatDate(_category.UpdatedAtUtc.Value)
                        </MudText>
                    }
                </MudStack>

                <MudSimpleTable Dense="true" Hover="true">
                    <tbody>
                        <tr>
                            <td>Name</td>
                            <td>@_category.Name</td>
                        </tr>
                        <tr>
                            <td>Description</td>
                            <td>@DisplayDescription(_category)</td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudStack>
        </MudPaper>
    </MudStack>
}

@code {
    private CategoryResponse? _category;
    private bool _isLoading = true;
    private bool _isDeleting;

    [Parameter]
    public Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _category = await CategoriesApiClient.GetByIdAsync(Id);
        }
        catch (ApiException exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_category is null)
        {
            return;
        }

        _isDeleting = true;

        try
        {
            var impact = await CategoriesApiClient.GetDeleteImpactAsync(_category.Id);

            if (impact is null)
            {
                Snackbar.Add("Category not found.", Severity.Warning);
                Navigation.NavigateTo("/categories");
                return;
            }

            _isDeleting = false;

            var confirmed = await ShowDeleteDialogAsync(
                "Delete category",
                BuildDeleteMessage(impact),
                BuildLinkedProductPreview(impact));

            if (!confirmed)
            {
                return;
            }

            _isDeleting = true;

            var deleted = await CategoriesApiClient.DeleteAsync(_category.Id);

            if (!deleted)
            {
                Snackbar.Add("Category not found.", Severity.Warning);
                Navigation.NavigateTo("/categories");
                return;
            }

            Snackbar.Add("Category deleted.", Severity.Success);
            Navigation.NavigateTo("/categories");
        }
        catch (ApiException exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private async Task<bool> ShowDeleteDialogAsync(
        string title,
        string message,
        IReadOnlyCollection<string>? items = null)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDeleteDialog.Message)] = message,
            [nameof(ConfirmDeleteDialog.Items)] = items ?? []
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ConfirmDeleteDialog>(title, parameters, options);
        var result = await dialog.Result;

        return result is { Canceled: false, Data: bool confirmed } && confirmed;
    }

    private static string BuildDeleteMessage(CategoryDeleteImpactResponse impact)
    {
        if (impact.LinkedProductsCount == 0)
        {
            return $"Are you sure you want to delete the category {impact.CategoryName}?";
        }

        return $"Are you sure you want to delete the category {impact.CategoryName}? It will be removed from the linked products below.";
    }

    private static IReadOnlyCollection<string> BuildLinkedProductPreview(CategoryDeleteImpactResponse impact)
    {
        if (impact.LinkedProductsCount == 0)
        {
            return [];
        }

        var products = impact.LinkedProducts
            .Select(product => $"{product.Code} ({product.Sku})")
            .ToList();

        if (impact.LinkedProductsCount > impact.LinkedProducts.Count)
        {
            products.Add("...");
        }

        return products;
    }

    private static string DisplayDescription(CategoryResponse category)
    {
        return string.IsNullOrWhiteSpace(category.Description)
            ? "-"
            : category.Description;
    }

    private static string FormatDate(DateTimeOffset value)
    {
        return value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }
}
