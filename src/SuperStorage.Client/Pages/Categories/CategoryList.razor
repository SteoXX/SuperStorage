@page "/categories"
@attribute [Authorize(Policy = AuthPolicies.CategoriesRead)]
@inject CategoriesApiClient CategoriesApiClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Categories</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4">Categories</MudText>
            <MudText Typo="Typo.body2">Maintain product classification data.</MudText>
        </MudStack>

        <AuthorizeView Policy="@AuthPolicies.CategoriesWrite">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Href="categories/new">
                New category
            </MudButton>
        </AuthorizeView>
    </MudStack>

    <MudPaper Class="pa-4" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End" Class="product-filter-bar">
            <MudTextField @bind-Value="_searchTerm"
                          Label="Search"
                          Placeholder="Name"
                          Immediate="true"
                          Disabled="_isBusy" />

            <MudSelect T="string"
                       @bind-Value="_selectedStatus"
                       Label="Status"
                       Disabled="_isBusy">
                <MudSelectItem T="string" Value="@AllValue">All</MudSelectItem>
                <MudSelectItem T="string" Value="@ActiveValue">Active</MudSelectItem>
                <MudSelectItem T="string" Value="@InactiveValue">Inactive</MudSelectItem>
            </MudSelect>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="_isBusy"
                       StartIcon="@Icons.Material.Filled.Search"
                       OnClick="SearchAsync">
                Search
            </MudButton>

            <MudButton Variant="Variant.Text"
                       Disabled="_isBusy"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="ResetAsync">
                Reset
            </MudButton>
        </MudStack>
    </MudPaper>

    <MudPaper Elevation="1">
        @if (_isBusy && _categories is null)
        {
            <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                <MudProgressCircular Indeterminate="true" />
            </MudStack>
        }
        else if (_categories is null || _categories.TotalCount == 0)
        {
            <MudStack AlignItems="AlignItems.Center" Class="pa-8" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Large" />
                <MudText Typo="Typo.h6">No categories found</MudText>
                <MudText Typo="Typo.body2">Adjust the filters or create the first category.</MudText>
            </MudStack>
        }
        else
        {
            <MudTable Items="Categories" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Updated</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate Context="category">
                    <MudTd DataLabel="Name">@category.Name</MudTd>
                    <MudTd DataLabel="Description">@DisplayDescription(category.Description)</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@(category.IsActive ? Color.Success : Color.Default)">
                            @(category.IsActive ? "Active" : "Inactive")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Updated">@FormatDate(category.UpdatedAtUtc ?? category.CreatedAtUtc)</MudTd>
                    <MudTd DataLabel="Actions" Class="product-actions">
                        <MudButton Variant="Variant.Text"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Visibility"
                                   Href="@($"categories/{category.Id}")">
                            View
                        </MudButton>
                        <AuthorizeView Policy="@AuthPolicies.CategoriesWrite" Context="writeAuthState">
                            <MudButton Variant="Variant.Text"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       Href="@($"categories/{category.Id}/edit")">
                                Edit
                            </MudButton>
                            <MudButton Variant="Variant.Text"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       Disabled="_isBusy"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => ConfirmDeleteAsync(category))">
                                Delete
                            </MudButton>
                        </AuthorizeView>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="pa-4">
                <MudText Typo="Typo.body2">
                    Page @_pageNumber of @Math.Max(_categories.TotalPages, 1) - @_categories.TotalCount categories
                </MudText>

                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Outlined"
                               Disabled="@(!_categories.HasPreviousPage || _isBusy)"
                               OnClick="PreviousPageAsync">
                        Previous
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Disabled="@(!_categories.HasNextPage || _isBusy)"
                               OnClick="NextPageAsync">
                        Next
                    </MudButton>
                </MudStack>
            </MudStack>
        }
    </MudPaper>
</MudStack>

@code {
    private const string AllValue = "";
    private const string ActiveValue = "active";
    private const string InactiveValue = "inactive";
    private const int PageSize = 20;

    private PagedResult<CategoryListItemResponse>? _categories;
    private string? _searchTerm;
    private string _selectedStatus = ActiveValue;
    private int _pageNumber = 1;
    private bool _isBusy;

    private IReadOnlyCollection<CategoryListItemResponse> Categories =>
        _categories?.Items ?? [];

    protected override async Task OnInitializedAsync()
    {
        await LoadCategoriesAsync();
    }

    private async Task SearchAsync()
    {
        _pageNumber = 1;
        await LoadCategoriesAsync();
    }

    private async Task ResetAsync()
    {
        _searchTerm = null;
        _selectedStatus = ActiveValue;
        _pageNumber = 1;
        await LoadCategoriesAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_pageNumber <= 1)
        {
            return;
        }

        _pageNumber--;
        await LoadCategoriesAsync();
    }

    private async Task NextPageAsync()
    {
        if (_categories is null || !_categories.HasNextPage)
        {
            return;
        }

        _pageNumber++;
        await LoadCategoriesAsync();
    }

    private async Task LoadCategoriesAsync()
    {
        _isBusy = true;

        try
        {
            _categories = await CategoriesApiClient.SearchAsync(
                _searchTerm,
                ParseStatus(),
                _pageNumber,
                PageSize);
        }
        catch (ApiException exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task ConfirmDeleteAsync(CategoryListItemResponse category)
    {
        _isBusy = true;

        try
        {
            var impact = await CategoriesApiClient.GetDeleteImpactAsync(category.Id);

            if (impact is null)
            {
                Snackbar.Add("Category not found.", Severity.Warning);
                await LoadCategoriesAsync();
                return;
            }

            _isBusy = false;

            var confirmed = await ShowDeleteDialogAsync(
                "Delete category",
                BuildDeleteMessage(impact),
                BuildLinkedProductPreview(impact));

            if (!confirmed)
            {
                return;
            }

            _isBusy = true;

            var deleted = await CategoriesApiClient.DeleteAsync(category.Id);

            if (!deleted)
            {
                Snackbar.Add("Category not found.", Severity.Warning);
                await LoadCategoriesAsync();
                return;
            }

            Snackbar.Add("Category deleted.", Severity.Success);
            await LoadCategoriesAsync();
        }
        catch (ApiException exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task<bool> ShowDeleteDialogAsync(
        string title,
        string message,
        IReadOnlyCollection<string>? items = null)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDeleteDialog.Message)] = message,
            [nameof(ConfirmDeleteDialog.Items)] = items ?? []
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ConfirmDeleteDialog>(title, parameters, options);
        var result = await dialog.Result;

        return result is { Canceled: false, Data: bool confirmed } && confirmed;
    }

    private static string BuildDeleteMessage(CategoryDeleteImpactResponse impact)
    {
        if (impact.LinkedProductsCount == 0)
        {
            return $"Are you sure you want to delete the category {impact.CategoryName}?";
        }

        return $"Are you sure you want to delete the category {impact.CategoryName}? It will be removed from the linked products below.";
    }

    private static IReadOnlyCollection<string> BuildLinkedProductPreview(CategoryDeleteImpactResponse impact)
    {
        if (impact.LinkedProductsCount == 0)
        {
            return [];
        }

        var products = impact.LinkedProducts
            .Select(product => $"{product.Code} ({product.Sku})")
            .ToList();

        if (impact.LinkedProductsCount > impact.LinkedProducts.Count)
        {
            products.Add("...");
        }

        return products;
    }

    private bool? ParseStatus()
    {
        return _selectedStatus switch
        {
            ActiveValue => true,
            InactiveValue => false,
            _ => null
        };
    }

    private static string DisplayDescription(string? description)
    {
        return string.IsNullOrWhiteSpace(description)
            ? "-"
            : description;
    }

    private static string FormatDate(DateTimeOffset value)
    {
        return value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }
}
